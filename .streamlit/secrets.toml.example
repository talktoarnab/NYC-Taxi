# Copy to `secrets.toml` in this folder for local `streamlit run app.py` (do not commit real tokens).
# Streamlit Community Cloud: paste the same keys in App settings → Secrets.

GITHUB_TOKEN = "ghp_..."
GITHUB_REPO = "owner/repo"
GHA_ARTIFACT_NAME = "etl-output"

# Optional: cache directory for downloaded artifact zips (default: ~/.cache/nyc_taxi_streamlit)
# NYC_TAXI_ARTIFACT_CACHE = "/var/cache/nyc_taxi"
